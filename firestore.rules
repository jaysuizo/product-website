rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isString(value) {
      return value is string;
    }

    function isOptionalString(value) {
      return value == null || value is string;
    }

    function isNumber(value) {
      return value is int || value is float;
    }

    function isOptionalNumber(value) {
      return value == null || value is int || value is float;
    }

    function isBool(value) {
      return value is bool;
    }

    function hasProductRequiredKeys(data) {
      return data.keys().hasAll([
        'name',
        'slug',
        'category',
        'featured',
        'stocks',
        'size',
        'images',
        'image',
        'updatedAt'
      ]);
    }

    function hasOnlyAllowedProductKeys(data) {
      return data.keys().hasOnly([
        'name',
        'slug',
        'category',
        'featured',
        'price',
        'stocks',
        'size',
        'images',
        'image',
        'video',
        'createdAt',
        'updatedAt'
      ]);
    }

    function isValidProduct(data) {
      return hasProductRequiredKeys(data) &&
        hasOnlyAllowedProductKeys(data) &&
        isString(data.name) &&
        isString(data.slug) &&
        isString(data.category) &&
        data.category.size() > 0 &&
        isBool(data.featured) &&
        isNumber(data.stocks) &&
        data.stocks >= 0 &&
        (isString(data.size) || data.size is list) &&
        data.images is list &&
        data.images.size() > 0 &&
        isString(data.image) &&
        data.image.size() > 0 &&
        (!('price' in data) || isOptionalNumber(data.price)) &&
        (!('video' in data) || isOptionalString(data.video)) &&
        data.updatedAt != null &&
        (!('createdAt' in data) || data.createdAt != null);
    }

    function isValidCustomerImage(data) {
      return data.keys().hasOnly([
        'image',
        'createdAt'
      ]) &&
      isString(data.image) &&
      data.image.size() > 0 &&
      data.createdAt != null;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'slug', 'updatedAt']) &&
        data.keys().hasOnly([
          'name',
          'slug',
          'image',
          'createdAt',
          'updatedAt',
          'updatedBy',
          'updatedByEmail'
        ]) &&
        isString(data.name) &&
        isString(data.slug) &&
        (!('image' in data) || isOptionalString(data.image)) &&
        (!('createdAt' in data) || data.createdAt != null) &&
        data.updatedAt != null &&
        (!('updatedBy' in data) || isOptionalString(data.updatedBy)) &&
        (!('updatedByEmail' in data) || isOptionalString(data.updatedByEmail));
    }

    function isValidSettings(data) {
      return data.keys().hasOnly([
        'storeName',
        'storeTagline',
        'storeLogo',
        'messengerLink',
        'contactDetails',
        'updatedAt',
        'updatedBy',
        'updatedByEmail'
      ]) &&
      (!('storeName' in data) || isOptionalString(data.storeName)) &&
      (!('storeTagline' in data) || isOptionalString(data.storeTagline)) &&
      (!('storeLogo' in data) || isOptionalString(data.storeLogo)) &&
      (!('messengerLink' in data) || isOptionalString(data.messengerLink)) &&
      (!('contactDetails' in data) || isOptionalString(data.contactDetails)) &&
      (!('updatedAt' in data) || data.updatedAt != null) &&
      (!('updatedBy' in data) || isOptionalString(data.updatedBy)) &&
      (!('updatedByEmail' in data) || isOptionalString(data.updatedByEmail));
    }

    function isValidInventoryLog(data) {
      return data.keys().hasOnly([
        'adminUid',
        'adminEmail',
        'action',
        'productId',
        'productName',
        'previousStock',
        'currentStock',
        'createdAt'
      ]) &&
      isString(data.adminUid) &&
      isString(data.adminEmail) &&
      isString(data.action) &&
      isString(data.productId) &&
      isString(data.productName) &&
      isNumber(data.previousStock) &&
      isNumber(data.currentStock) &&
      data.createdAt != null;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCategory(request.resource.data);
      allow update: if isAdmin() && isValidCategory(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create: if isAdmin() && isValidSettings(request.resource.data);
      allow update: if isAdmin() && isValidSettings(request.resource.data);
      allow delete: if false;
    }

    match /inventoryLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidInventoryLog(request.resource.data);
      allow update, delete: if false;
    }

    match /customerImages/{imageId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCustomerImage(request.resource.data);
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
